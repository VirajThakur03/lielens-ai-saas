DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*
DJANGO_SETTINGS_MODULE=core.settings

POSTGRES_DB=lielens
POSTGRES_USER=lielens
POSTGRES_PASSWORD=lielens
POSTGRES_HOST=db
POSTGRES_PORT=5432

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
STRIPE_SUCCESS_URL=http://localhost:8000/dashboard/?billing=success
STRIPE_CANCEL_URL=http://localhost:8000/dashboard/?billing=cancel

ANALYSIS_DISPATCH_MODE=sync
API_KEY_RATE_LIMIT_PER_MINUTE=30
API_KEY_RATE_LIMIT_PER_DAY=500
LIELENS_REWRITE_MODE=rule
OPENAI_REWRITE_MODEL=gpt-4.1-mini

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@lielens.local

SECURE_SSL_REDIRECT=0
SECURE_HSTS_SECONDS=31536000
REDIS_CACHE_URL=redis://redis:6379/2
